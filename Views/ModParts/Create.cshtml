@model Car_Mod_net.Models.ModPart

@{
    ViewData["Title"] = "SPEC REGISTRATION";
}

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end border-b border-zinc-900 pb-6 mb-10 gap-4">
        <div>
            <p class="text-rose-500 font-mono tracking-[0.25em] text-[10px] uppercase mb-1.5">// SYSTEM INTERFACE: MOD_ENTRY</p>
            <h1 class="text-3xl font-extrabold tracking-tight text-white uppercase">ADD NEW COMPONENT</h1>
        </div>
        <div>
            <a asp-action="Index" class="px-4 py-2 bg-zinc-950 hover:bg-zinc-900 border border-zinc-900 hover:border-zinc-700 text-zinc-500 hover:text-rose-500 text-xs font-mono tracking-widest uppercase transition-all rounded font-bold">
                [ ESC // CANCEL ]
            </a>
        </div>
    </div>

    <!-- Stark Control Panel Box -->
    <div class="border border-zinc-900 bg-zinc-950/40 p-8 rounded-lg relative backdrop-blur-sm shadow-xl shadow-rose-950/[0.02]">
        <!-- Technical Brackets -->
        <div class="absolute -top-[1px] -left-[1px] w-4 h-4 border-t-2 border-l-2 border-rose-600"></div>
        <div class="absolute -top-[1px] -right-[1px] w-4 h-4 border-t-2 border-r-2 border-rose-600"></div>
        <div class="absolute -bottom-[1px] -left-[1px] w-4 h-4 border-b-2 border-l-2 border-rose-600"></div>
        <div class="absolute -bottom-[1px] -right-[1px] w-4 h-4 border-b-2 border-r-2 border-rose-600"></div>

        <!-- Form -->
        <form asp-action="Create" method="post" class="space-y-8 text-sm">
            <div asp-validation-summary="ModelOnly" class="text-rose-500 font-mono text-xs uppercase bg-red-950/10 border border-red-500/20 p-4 rounded">// DIAGNOSTIC CHECK: ERROR DETECTED</div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Name -->
                <div class="space-y-2">
                    <div class="flex justify-between items-center">
                        <label asp-for="Name" class="block font-mono text-xs uppercase tracking-widest text-zinc-400">01 // Component Name</label>
                        <span asp-validation-for="Name" class="text-rose-500 font-mono text-[9px] uppercase tracking-wider"></span>
                    </div>
                    <input asp-for="Name" class="w-full bg-zinc-950 border border-zinc-800 focus:border-rose-500 focus:ring-1 focus:ring-rose-500/20 rounded px-4 py-3 text-white placeholder-zinc-800 outline-none transition-all font-mono text-xs" placeholder="e.g. ROUSH CARBON DIFFUSER" />
                </div>

                <!-- Category -->
                <div class="space-y-2">
                    <div class="flex justify-between items-center">
                        <label asp-for="Category" class="block font-mono text-xs uppercase tracking-widest text-zinc-400">02 // Category Group</label>
                        <span asp-validation-for="Category" class="text-rose-500 font-mono text-[9px] uppercase tracking-wider"></span>
                    </div>
                    <select asp-for="Category" class="w-full bg-zinc-950 border border-zinc-800 focus:border-rose-500 focus:ring-1 focus:ring-rose-500/20 rounded px-4 py-3 text-white outline-none transition-all font-mono text-xs uppercase tracking-wider">
                        <option value="Body Kit">Body Kit</option>
                        <option value="Wheels">Wheels</option>
                        <option value="Custom Paint">Paint & Wrap</option>
                        <option value="Window Tint">Stealth Tint</option>
                        <option value="Exhaust">Exhaust System</option>
                    </select>
                </div>

                <!-- Price -->
                <div class="space-y-2">
                    <div class="flex justify-between items-center">
                        <label asp-for="Price" class="block font-mono text-xs uppercase tracking-widest text-zinc-400">03 // Unit Price (USD)</label>
                        <span asp-validation-for="Price" class="text-rose-500 font-mono text-[9px] uppercase tracking-wider"></span>
                    </div>
                    <input asp-for="Price" type="number" step="0.01" class="w-full bg-zinc-950 border border-zinc-800 focus:border-rose-500 focus:ring-1 focus:ring-rose-500/20 rounded px-4 py-3 text-white placeholder-zinc-800 outline-none transition-all font-mono text-xs" placeholder="0.00" />
                </div>

                <!-- Image URL -->
                <div class="space-y-2">
                    <div class="flex justify-between items-center">
                        <label asp-for="ImageUrl" class="block font-mono text-xs uppercase tracking-widest text-zinc-400">04 // Image Asset Path</label>
                        <span asp-validation-for="ImageUrl" class="text-rose-500 font-mono text-[9px] uppercase tracking-wider"></span>
                    </div>
                    <input asp-for="ImageUrl" class="w-full bg-zinc-950 border border-zinc-800 focus:border-rose-500 focus:ring-1 focus:ring-rose-500/20 rounded px-4 py-3 text-white placeholder-zinc-800 outline-none transition-all font-mono text-xs" placeholder="/images/custom-part.jpg" />
                </div>
            </div>

            <!-- Description -->
            <div class="space-y-2">
                <div class="flex justify-between items-center">
                    <label asp-for="Description" class="block font-mono text-xs uppercase tracking-widest text-zinc-400">05 // Product Specification</label>
                    <span asp-validation-for="Description" class="text-rose-500 font-mono text-[9px] uppercase tracking-wider"></span>
                </div>
                <textarea asp-for="Description" rows="4" class="w-full bg-zinc-950 border border-zinc-800 focus:border-rose-500 focus:ring-1 focus:ring-rose-500/20 rounded px-4 py-3 text-white placeholder-zinc-800 outline-none transition-all font-mono text-xs resize-none" placeholder="Provide raw details, dimensions, composite materials, downforce numbers..."></textarea>
            </div>

            <!-- Compatibility Checkboxes -->
            <div class="border-t border-zinc-900 pt-6">
                <label class="block font-mono text-xs uppercase tracking-widest text-zinc-400 mb-4">06 // Platform Compatibility Mapping</label>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    @if (ViewBag.Vehicles != null)
                    {
                        foreach (var vehicle in (List<Car_Mod_net.Models.Vehicle>)ViewBag.Vehicles)
                        {
                            <label class="group flex items-center justify-between bg-zinc-950 hover:bg-zinc-900/50 border border-zinc-900 hover:border-zinc-700 p-4 rounded-lg cursor-pointer transition-all font-mono text-xs">
                                <span class="text-zinc-400 group-hover:text-white transition-colors">@vehicle.Year @vehicle.Make @vehicle.Model</span>
                                <input type="checkbox" name="selectedVehicleIds" value="@vehicle.Id" class="accent-rose-500 rounded border-zinc-800 focus:ring-0 w-4 h-4 bg-zinc-950" />
                            </label>
                        }
                    }
                </div>
            </div>

            <!-- Buttons -->
            <div class="flex items-center gap-4 border-t border-zinc-900 pt-6 font-mono text-xs">
                <button type="submit" class="px-6 py-3 bg-white text-black hover:bg-rose-600 hover:text-white transition-all font-extrabold uppercase tracking-widest rounded shadow-lg">
                    [ SUBMIT // COMMIT ]
                </button>
                <a asp-action="Index" class="px-6 py-3 text-zinc-500 hover:text-zinc-300 transition-colors uppercase tracking-widest">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
