@model Car_Mod_net.Models.ModPart

@{
    ViewData["Title"] = "UPDATE COMPONENT SPECIFICATION";
}

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="border-b border-zinc-900 pb-6 mb-10">
        <a asp-action="Index" class="text-xs font-mono tracking-widest text-zinc-500 hover:text-rose-500 transition-colors uppercase">
            &larr; Return to Inventory
        </a>
        <h1 class="text-3xl font-extrabold tracking-tight text-white uppercase mt-4">EDIT COMPONENT</h1>
        <p class="text-zinc-500 font-mono text-xs uppercase mt-1">// UPDATE TECHNICAL DATASHEET FOR SPEC: @Model.Id</p>
    </div>

    <!-- Form -->
    <form asp-action="Edit" method="post" class="space-y-6 text-sm">
        <div asp-validation-summary="ModelOnly" class="text-rose-500 font-mono text-xs"></div>
        <input type="hidden" asp-for="Id" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Name -->
            <div class="space-y-2">
                <label asp-for="Name" class="block font-mono text-xs uppercase tracking-widest text-zinc-400">Component Name</label>
                <input asp-for="Name" class="w-full bg-zinc-900 border border-zinc-800 focus:border-rose-500 rounded px-4 py-2 text-white placeholder-zinc-700 outline-none transition-colors" />
                <span asp-validation-for="Name" class="text-rose-500 font-mono text-[10px]"></span>
            </div>

            <!-- Category -->
            <div class="space-y-2">
                <label asp-for="Category" class="block font-mono text-xs uppercase tracking-widest text-zinc-400">Category Type</label>
                <select asp-for="Category" class="w-full bg-zinc-900 border border-zinc-800 focus:border-rose-500 rounded px-4 py-2 text-white outline-none transition-colors">
                    <option value="Body Kit">Body Kit</option>
                    <option value="Wheels">Wheels</option>
                    <option value="Custom Paint">Custom Paint & Wrap</option>
                    <option value="Window Tint">Stealth Window Tint</option>
                    <option value="Exhaust">Exhaust System</option>
                </select>
                <span asp-validation-for="Category" class="text-rose-500 font-mono text-[10px]"></span>
            </div>

            <!-- Price -->
            <div class="space-y-2">
                <label asp-for="Price" class="block font-mono text-xs uppercase tracking-widest text-zinc-400">Price (USD)</label>
                <input asp-for="Price" type="number" step="0.01" class="w-full bg-zinc-900 border border-zinc-800 focus:border-rose-500 rounded px-4 py-2 text-white outline-none transition-colors" />
                <span asp-validation-for="Price" class="text-rose-500 font-mono text-[10px]"></span>
            </div>

            <!-- Image URL -->
            <div class="space-y-2">
                <label asp-for="ImageUrl" class="block font-mono text-xs uppercase tracking-widest text-zinc-400">Image Asset URL</label>
                <input asp-for="ImageUrl" class="w-full bg-zinc-900 border border-zinc-800 focus:border-rose-500 rounded px-4 py-2 text-white outline-none transition-colors" />
                <span asp-validation-for="ImageUrl" class="text-rose-500 font-mono text-[10px]"></span>
            </div>
        </div>

        <!-- Description -->
        <div class="space-y-2">
            <label asp-for="Description" class="block font-mono text-xs uppercase tracking-widest text-zinc-400">Product Technical Description</label>
            <textarea asp-for="Description" rows="4" class="w-full bg-zinc-900 border border-zinc-800 focus:border-rose-500 rounded px-4 py-2 text-white outline-none transition-colors resize-none"></textarea>
            <span asp-validation-for="Description" class="text-rose-500 font-mono text-[10px]"></span>
        </div>

        <!-- Compatibility Checkboxes -->
        <div class="border-t border-zinc-900 pt-6">
            <label class="block font-mono text-xs uppercase tracking-widest text-zinc-400 mb-3">Vehicle Platform Compatibility</label>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                @if (ViewBag.Vehicles != null)
                {
                    foreach (var vehicle in (List<Car_Mod_net.Models.Vehicle>)ViewBag.Vehicles)
                    {
                        bool isChecked = Model.VehicleModParts != null && Model.VehicleModParts.Any(vmp => vmp.VehicleId == vehicle.Id);
                        <label class="flex items-center gap-3 bg-zinc-900/40 hover:bg-zinc-900 border border-zinc-800 hover:border-zinc-700 p-3 rounded cursor-pointer transition-all font-mono text-xs">
                            <input type="checkbox" name="selectedVehicleIds" value="@vehicle.Id" @(isChecked ? "checked" : "") class="accent-rose-500 rounded border-zinc-800 focus:ring-0 w-4 h-4 bg-zinc-900" />
                            <span class="text-zinc-300">@vehicle.Year @vehicle.Make @vehicle.Model</span>
                        </label>
                    }
                }
            </div>
        </div>

        <!-- Buttons -->
        <div class="flex items-center gap-4 border-t border-zinc-900 pt-6">
            <button type="submit" class="px-6 py-2.5 text-xs font-mono uppercase tracking-widest text-black bg-white hover:bg-rose-600 hover:text-white transition-all font-bold rounded">
                Save Changes
            </button>
            <a asp-action="Index" class="px-6 py-2.5 text-xs font-mono uppercase tracking-widest text-zinc-500 hover:text-zinc-300 transition-colors rounded">
                Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
