@model Car_Mod_net.Models.ModPart

@{
    ViewData["Title"] = Model.Name.ToUpper();
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb back link -->
    <div class="mb-8 font-mono text-xs">
        <a asp-action="Index" class="text-zinc-500 hover:text-rose-500 transition-colors uppercase">
            &larr; Return to Inventory
        </a>
    </div>

    <!-- Main Detail Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        
        <!-- Left Side: Large Premium Image -->
        <div class="lg:col-span-7 space-y-4">
            <div class="relative overflow-hidden bg-zinc-900 border border-zinc-800 rounded-xl shadow-2xl shadow-rose-950/10">
                <img src="@Model.ImageUrl" alt="@Model.Name" 
                     class="w-full h-[500px] object-cover object-center opacity-90"
                     onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'600\' height=\'400\' viewBox=\'0 0 600 400\'><rect width=\'100%\' height=\'100%\' fill=\'%230e0e11\'/><text x=\'50%\' y=\'50%\' dominant-baseline=\'middle\' text-anchor=\'middle\' fill=\'%233f3f46\' font-family=\'monospace\' font-size=\'18\'>IMAGE PENDING</text></svg>'">
                
                <!-- Category Floating Indicator -->
                <span class="absolute top-6 left-6 px-3 py-1 text-xs font-mono tracking-widest bg-black/90 text-rose-500 uppercase border border-rose-500/30 rounded">
                    @Model.Category
                </span>
            </div>
            
            <div class="flex justify-between items-center px-2 text-[10px] font-mono text-zinc-500">
                <span>SPEC-ID // #@Model.Id</span>
                <span>ASSET: @Model.ImageUrl</span>
            </div>
        </div>

        <!-- Right Side: Details Side-panel -->
        <div class="lg:col-span-5 space-y-8">
            <div>
                <p class="text-rose-500 font-mono tracking-widest text-[10px] uppercase mb-1">// SPECIFICATION DATASHEET</p>
                <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white uppercase leading-none">
                    @Model.Name
                </h1>
            </div>

            <!-- Price Detail Box -->
            <div class="bg-zinc-900/30 border border-zinc-900 p-6 rounded-lg font-mono flex justify-between items-center">
                <span class="text-xs text-zinc-500 uppercase">CATALOG PRICE</span>
                <span class="text-3xl font-extrabold text-white tracking-tighter">
                    $@Model.Price.ToString("N2")
                </span>
            </div>

            <!-- Description Block -->
            <div class="space-y-3">
                <h3 class="font-mono text-xs uppercase tracking-widest text-zinc-400 border-b border-zinc-900 pb-2">Technical Description</h3>
                <p class="text-zinc-300 text-sm leading-relaxed">
                    @Model.Description
                </p>
            </div>

            <!-- Compatible Vehicles -->
            <div class="space-y-4">
                <h3 class="font-mono text-xs uppercase tracking-widest text-zinc-400 border-b border-zinc-900 pb-2">Compatible Platforms</h3>
                <div class="flex flex-col gap-2">
                    @if (Model.VehicleModParts != null && Model.VehicleModParts.Any())
                    {
                        foreach (var vmp in Model.VehicleModParts)
                        {
                            <div class="flex items-center justify-between bg-zinc-900/20 border border-zinc-900/60 px-4 py-3 rounded text-xs font-mono">
                                <span class="text-white">@vmp.Vehicle.Year @vmp.Vehicle.Make @vmp.Vehicle.Model</span>
                                <span class="text-zinc-600 text-[10px]">VERIFIED MATCH</span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-xs text-zinc-500 font-mono bg-zinc-900/10 border border-zinc-900/30 p-4 rounded text-center">
                            Universal compatibility setup. Fits all platforms.
                        </div>
                    }
                </div>
            </div>

            <!-- Management Buttons -->
            <div class="pt-6 border-t border-zinc-900 flex items-center gap-4 text-xs font-mono">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="flex-1 text-center py-2.5 bg-white text-black hover:bg-rose-600 hover:text-white font-bold tracking-widest uppercase transition-all rounded">
                    Edit Component
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="flex-1 text-center py-2.5 bg-zinc-900 hover:bg-red-950/20 border border-zinc-800 hover:border-red-500/30 text-zinc-500 hover:text-red-500 tracking-widest uppercase transition-all rounded">
                    Decommission
                </a>
            </div>
        </div>

    </div>
</div>
