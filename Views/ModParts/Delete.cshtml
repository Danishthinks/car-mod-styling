@model Car_Mod_net.Models.ModPart

@{
    ViewData["Title"] = "DECOMMISSION COMPONENT SPEC";
}

<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- Danger Box Header -->
    <div class="border border-red-500/30 bg-red-950/10 p-6 rounded-lg mb-10 text-center">
        <span class="inline-block text-2xl mb-2 text-red-500">⚠️</span>
        <h2 class="text-lg font-bold text-white uppercase tracking-wider">Decommission Component?</h2>
        <p class="text-zinc-500 text-xs mt-1 font-mono uppercase">// THIS ACTION REMOVES ALL COMPATIBILITY MAPS AND PRODUCT SPECS PERMANENTLY</p>
    </div>

    <!-- Details Summary -->
    <div class="bg-zinc-950 border border-zinc-900 rounded-lg p-6 space-y-4 font-mono text-xs">
        <div class="flex justify-between border-b border-zinc-900 pb-2">
            <span class="text-zinc-500 uppercase">SPEC ID</span>
            <span class="text-white font-bold">@Model.Id</span>
        </div>
        <div class="flex justify-between border-b border-zinc-900 pb-2">
            <span class="text-zinc-500 uppercase">CATEGORY</span>
            <span class="text-white uppercase font-bold">@Model.Category</span>
        </div>
        <div class="flex justify-between border-b border-zinc-900 pb-2">
            <span class="text-zinc-500 uppercase">NAME</span>
            <span class="text-white font-bold text-sm">@Model.Name</span>
        </div>
        <div class="flex justify-between border-b border-zinc-900 pb-2">
            <span class="text-zinc-500 uppercase">PRICE</span>
            <span class="text-rose-500 font-bold">$@Model.Price.ToString("N2")</span>
        </div>
        <div class="border-b border-zinc-900 pb-2">
            <span class="text-zinc-500 uppercase block mb-1">DESCRIPTION</span>
            <p class="text-zinc-400 normal-case leading-relaxed font-sans text-xs">
                @Model.Description
            </p>
        </div>
        <div>
            <span class="text-zinc-500 uppercase block mb-1">PLATFORM COMPATIBILITIES</span>
            <div class="flex flex-wrap gap-1 mt-1">
                @if (Model.VehicleModParts != null && Model.VehicleModParts.Any())
                {
                    foreach (var vmp in Model.VehicleModParts)
                    {
                        <span class="px-2 py-0.5 text-[9px] bg-zinc-900 border border-zinc-800 text-zinc-400 rounded">
                            @vmp.Vehicle.Year @vmp.Vehicle.Make @vmp.Vehicle.Model
                        </span>
                    }
                }
                else
                {
                    <span class="text-zinc-600">No compatible vehicles mapped.</span>
                }
            </div>
        </div>
    </div>

    <!-- Confirm Form -->
    <form asp-action="Delete" method="post" class="mt-8 flex justify-center items-center gap-4">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="px-6 py-2.5 text-xs font-mono uppercase tracking-widest text-white bg-red-600 hover:bg-red-700 transition-colors font-bold rounded">
            Confirm Deletion
        </button>
        <a asp-action="Index" class="px-6 py-2.5 text-xs font-mono uppercase tracking-widest text-zinc-500 hover:text-zinc-300 transition-colors rounded">
            Cancel
        </a>
    </form>
</div>
