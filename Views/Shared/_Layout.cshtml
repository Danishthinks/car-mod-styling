<!DOCTYPE html>
<html lang="en" class="h-full bg-zinc-950">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] // RAW SPEC. Car Styling Catalog</title>
    
    <!-- Meta tags for SEO -->
    <meta name="description" content="RAW SPEC. Car Customization & Styling Catalog. Browse premium body kits, forged wheels, custom paint, performance exhaust systems and match compatibility." />
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Space Grotesk', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            glow: '#ff3333',
                            accent: '#ff0055',
                            dark: '#0a0a0a',
                            border: '#1f1f1f'
                        }
                    }
                }
            }
        }
    </script>
    
    <!-- Google Fonts: Space Grotesk -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Custom CSS styles if needed -->
    <style>
        /* Smooth custom glow scrollbar and styling details */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #0a0a0a;
        }
        ::-webkit-scrollbar-thumb {
            background: #1f1f1f;
            border-radius: 3px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #ff0055;
        }
        .glow-hover:hover {
            box-shadow: 0 0 15px rgba(255, 0, 85, 0.15);
        }
    </style>
</head>
<body class="h-full text-zinc-300 font-sans flex flex-col justify-between selection:bg-rose-600 selection:text-white">
    <div>
        <!-- Navigation Header -->
        <header class="border-b border-zinc-900 bg-black/80 backdrop-blur-md sticky top-0 z-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between h-16">
                    <div class="flex items-center gap-4 md:gap-8">
                        <!-- Brand Logo -->
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="flex items-center gap-2 group">
                            <span class="text-white font-extrabold tracking-widest text-sm sm:text-lg group-hover:text-rose-500 transition-colors">
                                RAW<span class="text-rose-500 group-hover:text-white transition-colors">SPEC.</span>
                            </span>
                            <span class="hidden xs:inline px-1.5 py-0.5 text-[8px] sm:text-[9px] font-mono tracking-widest bg-zinc-900 text-zinc-500 rounded border border-zinc-800">
                                SPEC
                            </span>
                        </a>
                        
                        <!-- Main Menu links -->
                        <nav class="hidden md:flex items-center gap-6">
                            <a asp-area="" asp-controller="Home" asp-action="Index" class="text-xs uppercase tracking-widest text-zinc-100 hover:text-rose-500 transition-colors font-medium">
                                Catalog
                            </a>
                            @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                            {
                                <a asp-controller="ModParts" asp-action="Index" class="text-xs uppercase tracking-widest text-zinc-100 hover:text-rose-500 transition-colors font-medium">
                                    Manage Catalog
                                </a>
                            }
                            <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-xs uppercase tracking-widest text-zinc-400 hover:text-rose-500 transition-colors font-medium">
                                Privacy
                            </a>
                        </nav>
                    </div>
                    
                    <div class="flex items-center gap-3 sm:gap-4">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <span class="hidden lg:inline px-3 py-1.5 bg-zinc-950 border border-zinc-900 text-zinc-500 rounded font-mono text-[10px] tracking-wider">
                                // OPERATOR: @User.Identity.Name
                            </span>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                                <button type="submit" class="px-2.5 sm:px-3.5 py-1.5 bg-zinc-950 hover:bg-rose-950/20 border border-zinc-900 hover:border-rose-500/30 text-zinc-500 hover:text-rose-500 transition-all rounded font-mono text-[9px] sm:text-[10px] font-bold uppercase tracking-widest">
                                    [ LOGOUT ]
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="px-2.5 sm:px-3.5 py-1.5 bg-white hover:bg-rose-600 text-black hover:text-white transition-all rounded font-mono text-[9px] sm:text-[10px] font-extrabold uppercase tracking-widest shadow-md">
                                [ LOGIN ]
                            </a>
                        }

                        <!-- Mobile Hamburger Button -->
                        <button onclick="toggleMobileMenu()" class="md:hidden flex flex-col justify-between w-5 h-3.5 text-zinc-400 hover:text-white focus:outline-none" aria-label="Toggle Navigation">
                            <span class="w-full h-0.5 bg-current transition-all duration-300 transform origin-first" id="hamburger-line1"></span>
                            <span class="w-full h-0.5 bg-current transition-all duration-300" id="hamburger-line2"></span>
                            <span class="w-full h-0.5 bg-current transition-all duration-300 transform origin-last" id="hamburger-line3"></span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Mobile Menu Dropdown -->
            <div id="mobile-menu" class="hidden md:hidden border-t border-zinc-900 bg-black/95 backdrop-blur-md py-4 px-6 space-y-3 font-mono text-[10px] tracking-widest">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="block py-1.5 text-zinc-100 hover:text-rose-500 transition-colors uppercase">
                    // CATALOG
                </a>
                @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                {
                    <a asp-controller="ModParts" asp-action="Index" class="block py-1.5 text-zinc-100 hover:text-rose-500 transition-colors uppercase">
                        // MANAGE CATALOG
                    </a>
                }
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="block py-1.5 text-zinc-400 hover:text-rose-500 transition-colors uppercase">
                    // PRIVACY POLICY
                </a>
            </div>
        </header>

        <script>
            function toggleMobileMenu() {
                var menu = document.getElementById("mobile-menu");
                var line1 = document.getElementById("hamburger-line1");
                var line2 = document.getElementById("hamburger-line2");
                var line3 = document.getElementById("hamburger-line3");
                
                if (menu.classList.contains("hidden")) {
                    menu.classList.remove("hidden");
                    line1.style.transform = "rotate(45deg) translate(4px, 4px)";
                    line2.style.opacity = "0";
                    line3.style.transform = "rotate(-45deg) translate(4px, -4px)";
                } else {
                    menu.classList.add("hidden");
                    line1.style.transform = "none";
                    line2.style.opacity = "1";
                    line3.style.transform = "none";
                }
            }
        </script>

        <!-- Main Body Wrapper -->
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer class="border-t border-zinc-900 bg-zinc-950/50 py-8 mt-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs font-mono text-zinc-600">
            <div>
                &copy; 2026 RAW SPEC. // Engineered for speed.
            </div>
            <div class="flex gap-4">
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="hover:text-rose-500 transition-colors">
                    Privacy Policy
                </a>
                <span>//</span>
                <span class="text-zinc-500">v1.0.0-dev</span>
            </div>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
