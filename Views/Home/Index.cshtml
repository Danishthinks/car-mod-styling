@model IEnumerable<Car_Mod_net.Models.ModPart>
@{
    ViewData["Title"] = "CATALOG";
}

<!-- Hero / Title Header Section -->
<section class="relative bg-black pt-16 pb-12 overflow-hidden border-b border-zinc-900">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-zinc-900/40 via-black to-black"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div>
                <p class="text-rose-500 font-mono tracking-[0.25em] text-xs uppercase mb-2">// HIGH-PERFORMANCE CUSTOMIZATION</p>
                <h1 class="text-4xl md:text-6xl font-extrabold tracking-tighter text-white uppercase">
                    STYLING CATALOG
                </h1>
                <p class="text-zinc-500 mt-2 text-sm max-w-md font-mono">
                    RAW SPECIFICATION COMPONENTS DESIGNED FOR OPTIMAL COMPATIBILITY AND UNCOMPROMISING AESTHETICS.
                </p>
            </div>
            
            <!-- Quick stats / design elements -->
            <div class="flex flex-wrap md:flex-nowrap gap-6 sm:gap-8 font-mono text-[10px] text-zinc-500">
                <div class="border-l border-zinc-800 pl-4">
                    <span class="block text-zinc-400 font-semibold text-sm">@Model.Count()</span>
                    ACTIVE COMPONENTS
                </div>
                <div class="border-l border-zinc-800 pl-4">
                    <span class="block text-zinc-400 font-semibold text-sm">4</span>
                    PLATFORMS SEEDED
                </div>
                <div class="border-l border-zinc-800 pl-4">
                    <span class="block text-zinc-400 font-semibold text-sm">SQLITE</span>
                    LOCAL ENGINE
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Filter and Main Content Area -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10" id="catalog">
    <!-- Dual-Filter Panel -->
    <div class="flex flex-col lg:flex-row gap-6 justify-between items-start lg:items-center border-b border-zinc-900 pb-6 mb-10 text-xs font-mono">
        <!-- Category Filters -->
        <div class="flex flex-wrap gap-2">
            <button onclick="setCategory('All')" id="btn-all" class="filter-btn px-4 py-2 border border-rose-500/30 text-rose-500 bg-rose-950/20 hover:border-rose-500 transition-all uppercase tracking-widest rounded">
                [ All Parts ]
            </button>
            <button onclick="setCategory('Body Kit')" id="btn-bodykit" class="filter-btn px-4 py-2 border border-zinc-800 text-zinc-400 hover:text-white hover:border-zinc-500 transition-all uppercase tracking-widest rounded">
                Body Kits
            </button>
            <button onclick="setCategory('Wheels')" id="btn-wheels" class="filter-btn px-4 py-2 border border-zinc-800 text-zinc-400 hover:text-white hover:border-zinc-500 transition-all uppercase tracking-widest rounded">
                Wheels
            </button>
            <button onclick="setCategory('Custom Paint')" id="btn-paint" class="filter-btn px-4 py-2 border border-zinc-800 text-zinc-400 hover:text-white hover:border-zinc-500 transition-all uppercase tracking-widest rounded">
                Paint & Wraps
            </button>
            <button onclick="setCategory('Window Tint')" id="btn-tint" class="filter-btn px-4 py-2 border border-zinc-800 text-zinc-400 hover:text-white hover:border-zinc-500 transition-all uppercase tracking-widest rounded">
                Stealth Tint
            </button>
            <button onclick="setCategory('Exhaust')" id="btn-exhaust" class="filter-btn px-4 py-2 border border-zinc-800 text-zinc-400 hover:text-white hover:border-zinc-500 transition-all uppercase tracking-widest rounded">
                Exhausts
            </button>
        </div>

        <!-- Vehicle Platform Compatibility Dropdown -->
        <div class="flex items-center gap-3 w-full lg:w-auto">
            <label for="vehicle-select" class="text-zinc-500 uppercase tracking-wider text-[10px]">PLATFORM MATCH:</label>
            <select id="vehicle-select" onchange="setVehicle(this.value)" class="bg-zinc-900 border border-zinc-800 focus:border-rose-500 text-zinc-300 rounded px-4 py-2 outline-none transition-colors w-full lg:w-64 uppercase tracking-wider text-xs">
                <option value="All">[ ALL VEHICLES ]</option>
                @if (ViewBag.Vehicles != null)
                {
                    foreach (var vehicle in (List<Car_Mod_net.Models.Vehicle>)ViewBag.Vehicles)
                    {
                        <option value="@vehicle.Id">@vehicle.Year @vehicle.Make @vehicle.Model</option>
                    }
                }
            </select>
        </div>
    </div>

    <!-- Catalog Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        @foreach (var part in Model)
        {
            var cleanCategoryClass = part.Category.Replace(" ", "").ToLower();
            <div class="part-card group border border-zinc-900 bg-zinc-950/40 rounded-lg overflow-hidden hover:border-zinc-700 transition-all duration-300 flex flex-col justify-between" 
                 data-category="@part.Category"
                 data-vehicles="@(part.VehicleModParts != null ? string.Join(",", part.VehicleModParts.Select(vmp => vmp.VehicleId)) : "")">
                
                <div>
                    <!-- Part Image Block -->
                    <div class="relative h-60 w-full overflow-hidden bg-zinc-900 border-b border-zinc-900">
                        <img src="@part.ImageUrl" alt="@part.Name" 
                             class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-500 opacity-80 group-hover:opacity-100"
                             onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'300\' height=\'200\' viewBox=\'0 0 300 200\'><rect width=\'100%\' height=\'100%\' fill=\'%230e0e11\'/><text x=\'50%\' y=\'50%\' dominant-baseline=\'middle\' text-anchor=\'middle\' fill=\'%233f3f46\' font-family=\'monospace\' font-size=\'14\'>IMAGE PENDING</text></svg>'">
                        
                        <!-- Floating Category Label -->
                        <span class="absolute top-4 left-4 px-2 py-0.5 text-[9px] font-mono tracking-widest bg-black/90 text-zinc-400 uppercase border border-zinc-800 rounded">
                            @part.Category
                        </span>

                        <!-- Floating Price Tag -->
                        <span class="absolute bottom-4 right-4 px-3 py-1 text-xs font-mono font-bold tracking-tight bg-zinc-950 text-white border border-zinc-800 rounded shadow-lg">
                            $@part.Price.ToString("N2")
                        </span>
                    </div>

                    <!-- Card Body -->
                    <div class="p-6">
                        <h3 class="text-lg font-bold text-white tracking-tight uppercase group-hover:text-rose-500 transition-colors">
                            @part.Name
                        </h3>
                        
                        <p class="text-zinc-500 text-xs mt-2 line-clamp-2 leading-relaxed">
                            @part.Description
                        </p>
                        
                        <!-- Compatibility Information -->
                        <div class="mt-6 border-t border-zinc-900/50 pt-4">
                            <span class="text-[9px] font-mono tracking-widest text-zinc-500 uppercase block mb-2">
                                COMPATIBLE PLATFORMS
                            </span>
                            <div class="flex flex-wrap gap-1.5">
                                @if (part.VehicleModParts != null && part.VehicleModParts.Any())
                                {
                                    foreach (var vmp in part.VehicleModParts)
                                    {
                                        <span class="px-2 py-0.5 text-[10px] font-mono bg-zinc-900/60 border border-zinc-800 text-zinc-400 rounded">
                                            @vmp.Vehicle.Year @vmp.Vehicle.Make @vmp.Vehicle.Model
                                        </span>
                                    }
                                }
                                else
                                {
                                    <span class="text-[10px] font-mono text-zinc-600">Universal Compatibility</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer Card Action -->
                <div class="px-6 pb-6 pt-2">
                    <a asp-controller="ModParts" asp-action="Details" asp-route-id="@part.Id" class="block w-full text-center py-2 bg-zinc-900 hover:bg-rose-600 hover:text-white border border-zinc-800 hover:border-transparent text-xs font-mono tracking-widest uppercase transition-all rounded font-semibold text-zinc-400">
                        View Component Details
                    </a>
                </div>

            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        let activeCategory = 'All';
        let activeVehicle = 'All';

        function setCategory(category) {
            activeCategory = category;
            
            // Manage category buttons active classes
            const buttons = document.querySelectorAll('.filter-btn');
            buttons.forEach(btn => {
                btn.classList.remove('border-rose-500/30', 'text-rose-500', 'bg-rose-950/20', 'border-rose-500');
                btn.classList.add('border-zinc-800', 'text-zinc-400');
            });

            let targetBtnId = 'btn-all';
            if (category === 'Body Kit') targetBtnId = 'btn-bodykit';
            else if (category === 'Wheels') targetBtnId = 'btn-wheels';
            else if (category === 'Custom Paint') targetBtnId = 'btn-paint';
            else if (category === 'Window Tint') targetBtnId = 'btn-tint';
            else if (category === 'Exhaust') targetBtnId = 'btn-exhaust';

            const activeBtn = document.getElementById(targetBtnId);
            if (activeBtn) {
                activeBtn.classList.remove('border-zinc-800', 'text-zinc-400');
                activeBtn.classList.add('border-rose-500/30', 'text-rose-500', 'bg-rose-950/20', 'border-rose-500');
            }

            applyFilters();
        }

        function setVehicle(vehicleId) {
            activeVehicle = vehicleId;
            applyFilters();
        }

        function applyFilters() {
            const cards = document.querySelectorAll('.part-card');

            cards.forEach(card => {
                const cardCategory = card.getAttribute('data-category');
                const cardVehiclesAttr = card.getAttribute('data-vehicles');
                const cardVehicles = cardVehiclesAttr ? cardVehiclesAttr.split(',') : [];

                const matchCategory = (activeCategory === 'All' || cardCategory === activeCategory);
                const matchVehicle = (activeVehicle === 'All' || cardVehicles.includes(activeVehicle));

                if (matchCategory && matchVehicle) {
                    card.style.display = 'flex';
                } else {
                    card.style.display = 'none';
                }
            });
        }
    </script>
}
