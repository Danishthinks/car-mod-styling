@model Car_Mod_net.Models.LoginViewModel

@{
    ViewData["Title"] = "AUTHENTICATION PROTOCOL";
}

<div class="max-w-md mx-auto px-4 py-20">
    <!-- Header -->
    <div class="text-center mb-10">
        <p class="text-rose-500 font-mono tracking-[0.3em] text-[10px] uppercase mb-2">// SECURE SYSTEM LINK: AUTH_REQUIRED</p>
        <h1 class="text-3xl font-extrabold tracking-tight text-white uppercase">CONTROL CONSOLE</h1>
    </div>

    <!-- Login Console Card -->
    <div class="border border-zinc-900 bg-zinc-950/40 p-8 rounded-lg relative backdrop-blur-sm shadow-2xl shadow-rose-950/[0.01]">
        <!-- Technical Red Corner Brackets -->
        <div class="absolute -top-[1px] -left-[1px] w-4 h-4 border-t-2 border-l-2 border-rose-600"></div>
        <div class="absolute -top-[1px] -right-[1px] w-4 h-4 border-t-2 border-r-2 border-rose-600"></div>
        <div class="absolute -bottom-[1px] -left-[1px] w-4 h-4 border-b-2 border-l-2 border-rose-600"></div>
        <div class="absolute -bottom-[1px] -right-[1px] w-4 h-4 border-b-2 border-r-2 border-rose-600"></div>

        <!-- Form -->
        <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="space-y-6">
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="text-rose-500 font-mono text-[11px] uppercase tracking-wider bg-red-950/10 border border-red-500/20 p-4 rounded text-center">
                    // AUTHENTICATION FAILURE DETECTED
                </div>
            }

            <!-- Email Address -->
            <div class="space-y-2">
                <div class="flex justify-between items-center">
                    <label asp-for="Email" class="block font-mono text-xs uppercase tracking-widest text-zinc-400">01 // Operator Email</label>
                    <span asp-validation-for="Email" class="text-rose-500 font-mono text-[9px] uppercase tracking-wider"></span>
                </div>
                <input asp-for="Email" class="w-full bg-zinc-950 border border-zinc-800 focus:border-rose-500 focus:ring-1 focus:ring-rose-500/20 rounded px-4 py-3 text-white placeholder-zinc-800 outline-none transition-all font-mono text-xs" placeholder="admin@rawspec.com" />
            </div>

            <!-- Password -->
            <div class="space-y-2">
                <div class="flex justify-between items-center">
                    <label asp-for="Password" class="block font-mono text-xs uppercase tracking-widest text-zinc-400">02 // Passphrase</label>
                    <span asp-validation-for="Password" class="text-rose-500 font-mono text-[9px] uppercase tracking-wider"></span>
                </div>
                <input asp-for="Password" class="w-full bg-zinc-950 border border-zinc-800 focus:border-rose-500 focus:ring-1 focus:ring-rose-500/20 rounded px-4 py-3 text-white placeholder-zinc-800 outline-none transition-all font-mono text-xs" placeholder="••••••••••••" />
            </div>

            <!-- Remember Me -->
            <div class="flex items-center justify-between font-mono text-xs py-1">
                <label class="group flex items-center gap-3 cursor-pointer text-zinc-400 hover:text-white transition-colors">
                    <input asp-for="RememberMe" class="accent-rose-500 rounded border-zinc-800 focus:ring-0 w-4 h-4 bg-zinc-950" />
                    <span>Keep session active</span>
                </label>
            </div>

            <!-- Submit Buttons -->
            <div class="pt-2 font-mono text-xs">
                <button type="submit" class="w-full py-3.5 bg-white text-black hover:bg-rose-600 hover:text-white transition-all font-extrabold uppercase tracking-widest rounded shadow-lg">
                    [ ESTABLISH // LINK ]
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
